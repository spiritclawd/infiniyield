# Network Configuration
# Options: mainnet, sepolia
NEXT_PUBLIC_NETWORK=mainnet

# Platform Fee Recipient (10% of entry fees)
# Replace with your actual Starknet address
NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=0x0

# Vault Contract Address (after deployment)
# The vault that receives 90% of entry fees and generates yield
NEXT_PUBLIC_VAULT_CONTRACT=0x0

# Cartridge Controller Configuration
# Your Cartridge namespace for the game
NEXT_PUBLIC_CARTRIDGE_NAMESPACE=infiniyield

# Optional: BTC Price API for USD display
NEXT_PUBLIC_BTC_PRICE_API=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd
