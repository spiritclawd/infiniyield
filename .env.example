# INFINIYIELD Environment Variables
# Copy to .env.local for local development

# Network: "mainnet" or "sepolia"
NEXT_PUBLIC_NETWORK=mainnet

# Platform fee recipient address (10% of entry fees)
NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=0xYOUR_PLATFORM_ADDRESS

# Vault contract address (after deployment)
NEXT_PUBLIC_VAULT_CONTRACT=0xYOUR_VAULT_CONTRACT

# Cartridge Controller namespace
NEXT_PUBLIC_CARTRIDGE_NAMESPACE=infiniyield
